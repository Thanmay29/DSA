/*
Question:
Given the head of a singly linked list, return the length of the loop.
If no loop exists, return 0.

Approach:
1. Use Floyd's Cycle Detection Algorithm.
   - slow moves 1 step.
   - fast moves 2 steps.
2. If slow == fast, a cycle exists.
3. Start from slow.next and keep moving until we reach slow again.
4. Count the number of nodes visited.
5. If no cycle is found, return 0.

Example:
1 -> 2 -> 3 -> 4 -> 5
     ^              |
     |______________|

Loop = 2 -> 3 -> 4 -> 5
Length = 4
*/

/* Definition of singly linked list
class ListNode {
    int val;
    ListNode next;

    ListNode() {
        val = 0;
        next = null;
    }

    ListNode(int data1) {
        val = data1;
        next = null;
    }

    ListNode(int data1, ListNode next1) {
        val = data1;
        next = next1;
    }
}
*/

class Solution {

    public int findLengthOfLoop(ListNode head) {

        // Slow pointer moves one step
        ListNode slow = head;

        // Fast pointer moves two steps
        ListNode fast = head;

        // Continue while fast can move two steps safely
        while (fast != null && fast.next != null) {

            // Move pointers
            slow = slow.next;
            fast = fast.next.next;

            // If both meet, a cycle exists
            if (slow == fast) {

                // We have already counted the meeting node
                int length = 1;

                // Start from the next node in the cycle
                ListNode curr = slow.next;

                // Traverse one complete cycle
                while (curr != slow) {
                    length++;
                    curr = curr.next;
                }

                // Return the loop length
                return length;
            }
        }

        // No cycle found
        return 0;
    }
}
